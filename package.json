{
  "name": "paibp-web",
  "version": "0.1.1",
  "private": true,
  "description": "Smart Assessment System for PAIBP",
  "author": "DEVELZY",
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:cf": "npx @cloudflare/next-on-pages@1",
    "build:exe": "set \"NEXT_PUBLIC_EXPORT=true\" && set \"CSC_IDENTITY_AUTO_DISCOVERY=false\" && (if exist dist rd /s /q dist) && (if exist out rd /s /q out) && (if exist src\\app\\api ren src\\app\\api _api) && next build && (if exist src\\app\\_api ren src\\app\\_api api) && electron-builder",
    "electron:dev": "electron .",
    "start": "next start",
    "lint": "eslint"
  },
  "build": {
    "appId": "com.develzy.paibp",
    "productName": "PAIBP Assessment",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "portable",
      "icon": "public/logo.png",
      "forceCodeSigning": false
    },
    "publish": [
      {
        "provider": "github",
        "owner": "develzy",
        "repo": "paibp"
      }
    ]
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hot-toast": "^2.6.0",
    "tailwind-merge": "^3.6.0",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.13",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
